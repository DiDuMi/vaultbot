{
  "name": "vaultbot",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker/index.ts",
    "test": "tsx src/tests/run.ts",
    "lint": "eslint . --max-warnings=0",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preflight:tenant": "node scripts/preflight-tenant.js"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "bullmq": "^4.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.7.4",
    "grammy": "^1.35.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prisma": "^5.11.0",
    "tsx": "^4.7.1",
    "typescript": "5.5.4"
  }
}
